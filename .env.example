# ============================================================
#  VisionTale Creator — Environment Variable Template
#  Copy to .env.local and fill in real values.
#  This file is safe to commit — it has no real secrets.
# ============================================================

# REQUIRED — Groq API key for story generation (chat completions)
# Get yours free at https://console.groq.com/keys
GROQ_API_KEY=

# OPTIONAL — override Groq story model (default: llama-3.3-70b-versatile)
# GROQ_MODEL=

# REQUIRED for narration — ElevenLabs text-to-speech (no OpenAI TTS)
# Get yours at https://elevenlabs.io/
ELEVENLABS_API_KEY=

# OPTIONAL — ElevenLabs voice (Rachel default, or Adam)
# ELEVENLABS_VOICE_NAME=Rachel
# ELEVENLABS_VOICE_ID=

# Images use Pollinations server-side (FREE, no API key) — model: turbo

# REQUIRED — OpenRouter API key for story generation
# Get yours free at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# OPTIONAL — TTS narration (pick one or more)
# ElevenLabs: https://elevenlabs.io/
ELEVENLABS_API_KEY=
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=
# PlayHT: https://play.ht/
PLAYHT_API_KEY=
